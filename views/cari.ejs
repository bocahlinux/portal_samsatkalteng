<%- include("partials/head") %>
<%- include("partials/topbar") %>
<%- include("partials/header") %>
<%- include("partials/nav") %>
<%- include("partials/breadcrumbs") %>

<main id="main" class="container py-4">
  <h1 class="h4 fw-bold mb-1">Pencarian</h1>

  <form class="mt-3" method="GET" action="/cari">
    <div class="input-group">
      <input name="q" class="form-control" value="<%= q %>" placeholder="Ketik kata kunci..." />
      <button class="btn btn-primary" type="submit"><i class="bi bi-search"></i></button>
    </div>
  </form>

  <% if (!q) { %>
    <p class="text-secondary mt-3">Masukkan kata kunci untuk mencari layanan atau berita.</p>
  <% } else { %>
    <div class="mt-4">
      <h2 class="h6 fw-semibold">Hasil Layanan</h2>
      <% if (!layananHit.length) { %><div class="text-secondary">Tidak ada hasil.</div><% } %>
      <div class="row g-3 mt-1">
        <% layananHit.forEach(l => { %>
          <div class="col-lg-6">
            <div class="card border-0 shadow-sm">
              <div class="card-body">
                <div class="fw-semibold"><%= l.name %></div>
                <div class="text-secondary"><%= l.ringkas %></div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    </div>

    <div class="mt-4">
      <h2 class="h6 fw-semibold">Hasil Berita</h2>
      <% if (!beritaHit.length) { %><div class="text-secondary">Tidak ada hasil.</div><% } %>
      <div class="row g-3 mt-1">
        <% beritaHit.forEach(b => { %>
          <div class="col-lg-6">
            <a class="card border-0 shadow-sm card-link" href="/berita/<%= b.slug %>">
              <div class="card-body">
                <div class="small text-secondary"><%= b.date %></div>
                <div class="fw-semibold"><%= b.title %></div>
                <div class="text-secondary text-truncate-2"><%= b.content %></div>
              </div>
            </a>
          </div>
        <% }) %>
      </div>
    </div>
  <% } %>
</main>

<%- include("partials/footer") %>