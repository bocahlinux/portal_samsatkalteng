<%- include("partials/head") %>
<%- include("partials/header") %>

<main id="main" class="container py-5">
  <h1 class="h3 fw-bold">Kontak</h1>
  <p class="text-secondary">Saluran bantuan (placeholder). Ganti dengan data resmi instansi.</p>

  <div class="row g-3 mt-2">
    <div class="col-lg-6">
      <div class="card shadow-sm border-0">
        <div class="card-body">
          <div class="fw-semibold">Informasi Kontak</div>
          <div class="mt-2"><b>Alamat:</b> <%= kontak.alamat %></div>
          <div class="mt-2"><b>Email:</b> <%= kontak.email %></div>
          <div class="mt-2"><b>Telepon:</b> <%= kontak.telp %></div>

          <hr/>
          <div class="small text-secondary">
            <!-- Tips: untuk instansi, biasanya diminta ada kanal pengaduan resmi + jam layanan + SLA respon. -->
          </div>
        </div>
      </div>
    </div>

    <div class="col-lg-6">
      <div class="card shadow-sm border-0">
        <div class="card-body">
          <div class="fw-semibold">Form Pengaduan (Dummy)</div>
          <form class="mt-3" onsubmit="return false;">
            <div class="mb-2">
              <label class="form-label">Nama</label>
              <input class="form-control" placeholder="Nama pelapor" />
            </div>
            <div class="mb-2">
              <label class="form-label">Kontak</label>
              <input class="form-control" placeholder="Nomor HP / Email" />
            </div>
            <div class="mb-2">
              <label class="form-label">Pesan</label>
              <textarea class="form-control" rows="4" placeholder="Tuliskan keluhan/pertanyaan"></textarea>
            </div>
            <button class="btn btn-primary" type="submit" disabled>Kirim (belum diaktifkan)</button>
            <div class="small text-secondary mt-2">
              Nanti bisa kamu sambungkan ke API internal / ticketing.
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include("partials/footer") %>