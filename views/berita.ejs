<%- include("partials/head") %>
<%- include("partials/topbar") %>
<%- include("partials/header") %>
<%- include("partials/nav") %>
<%- include("partials/breadcrumbs") %>

<main id="main" class="container py-4">
  <h1 class="h4 fw-bold mb-1">Berita & Pengumuman</h1>
  <p class="text-secondary">Informasi resmi yang dipublikasikan melalui portal.</p>

  <div class="row g-3 mt-2">
    <% berita.forEach(b => { %>
      <div class="col-md-6 col-lg-4">
        <a class="card h-100 shadow-sm border-0 card-link" href="/berita/<%= b.slug %>">
          <div class="card-body">
            <div class="small text-secondary"><%= b.date %></div>
            <div class="fw-semibold mt-1"><%= b.title %></div>
            <div class="text-secondary mt-2 text-truncate-2"><%= b.content %></div>
          </div>
        </a>
      </div>
    <% }) %>
  </div>
</main>

<%- include("partials/footer") %>