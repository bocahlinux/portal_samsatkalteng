<%- include("partials/head") %>
<%- include("partials/topbar") %>
<%- include("partials/header") %>
<%- include("partials/nav") %>

<main id="main">
  <section class="hero">
    <div class="container py-5">
      <div class="row g-4 align-items-center">
        <div class="col-lg-7">
          <div class="badge bg-light text-primary border mb-2">Informasi & Layanan</div>
          <h1 class="display-6 fw-bold mb-2">Portal Layanan Samsat Kalimantan Tengah</h1>
          <p class="lead text-secondary mb-4">
            Informasi standar pelayanan, pengumuman, unduhan, PPID, serta kanal pengaduan.
          </p>

          <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-primary" href="/layanan"><i class="bi bi-grid"></i> Layanan</a>
            <a class="btn btn-outline-primary" href="/ppid"><i class="bi bi-journal-text"></i> PPID</a>
            <a class="btn btn-outline-secondary" href="/pengaduan"><i class="bi bi-megaphone"></i> Pengaduan</a>
          </div>

          <div class="row g-3 mt-4">
            <% statistik.forEach(s => { %>
              <div class="col-md-4">
                <div class="stat-card">
                  <div class="stat-label"><%= s.label %></div>
                  <div class="stat-value"><%= s.value %></div>
                </div>
              </div>
            <% }) %>
          </div>
        </div>

        <div class="col-lg-5">
          <div class="card shadow-sm border-0">
            <div class="card-body">
              <div class="fw-semibold mb-2">Akses Cepat</div>
              <div class="quick-links">
                <a class="quick-link" href="/layanan">
                  <i class="bi bi-card-checklist"></i>
                  <span>Standar Layanan</span>
                </a>
                <a class="quick-link" href="/unduhan">
                  <i class="bi bi-download"></i>
                  <span>Formulir & Dokumen</span>
                </a>
                <a class="quick-link" href="/berita">
                  <i class="bi bi-megaphone"></i>
                  <span>Pengumuman</span>
                </a>
                <a class="quick-link" href="/ppid">
                  <i class="bi bi-info-circle"></i>
                  <span>Informasi Publik</span>
                </a>
              </div>
              <div class="small text-secondary mt-3">
                Catatan internal: tombol “Cek Pajak” bisa kamu sambungkan ke API internal (SOP + kontrol akses).
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container pb-5">
    <div class="d-flex align-items-center justify-content-between mb-3">
      <h2 class="h5 mb-0">Layanan Unggulan</h2>
      <a class="small" href="/layanan">Lihat semua</a>
    </div>

    <div class="row g-3">
      <% layananUnggulan.forEach(l => { %>
        <div class="col-md-4">
          <div class="card h-100 shadow-sm border-0">
            <div class="card-body">
              <div class="fw-semibold"><%= l.name %></div>
              <div class="text-secondary mt-2"><%= l.ringkas %></div>
              <div class="mt-3 small text-secondary"><i class="bi bi-clock"></i> <%= l.estimasi %></div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </section>

  <section class="container pb-5">
    <div class="d-flex align-items-center justify-content-between mb-3">
      <h2 class="h5 mb-0">Berita & Pengumuman</h2>
      <a class="small" href="/berita">Lihat semua</a>
    </div>

    <div class="row g-3">
      <% beritaTerbaru.forEach(b => { %>
        <div class="col-md-6 col-lg-4">
          <a class="card h-100 shadow-sm border-0 card-link" href="/berita/<%= b.slug %>">
            <div class="card-body">
              <div class="small text-secondary"><%= b.date %></div>
              <div class="fw-semibold mt-1"><%= b.title %></div>
              <div class="text-secondary mt-2 text-truncate-2"><%= b.content %></div>
            </div>
          </a>
        </div>
      <% }) %>
    </div>
  </section>
</main>

<%- include("partials/footer") %>