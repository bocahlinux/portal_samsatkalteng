<%- include("partials/head") %>
<%- include("partials/topbar") %>
<%- include("partials/header") %>
<%- include("partials/nav") %>
<%- include("partials/breadcrumbs") %>

<main id="main" class="container py-4">
  <h1 class="h4 fw-bold mb-1">Layanan</h1>
  <p class="text-secondary">Informasi layanan dan persyaratan umum. (Sesuaikan SOP & standar pelayanan instansi.)</p>

  <div class="row g-3 mt-2">
    <% layanan.forEach(l => { %>
      <div class="col-lg-6">
        <div class="card h-100 shadow-sm border-0">
          <div class="card-body">
            <div class="fw-semibold"><%= l.name %></div>
            <div class="text-secondary mt-1"><%= l.ringkas %></div>

            <div class="mt-3 small text-secondary"><i class="bi bi-clock"></i> Estimasi: <%= l.estimasi %></div>

            <div class="mt-3 fw-semibold small">Persyaratan umum</div>
            <ul class="mb-0">
              <% l.persyaratan.forEach(p => { %><li><%= p %></li><% }) %>
            </ul>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
</main>

<%- include("partials/footer") %>